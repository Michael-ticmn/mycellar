# Copy to .env on the VM and fill in.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Bridge directory layout (folders auto-created at startup).
# Default: ~/cellar27-bridge on Linux/macOS.
# On Windows, set to e.g. C:/Users/michael/cellar27-bridge
BRIDGE_DIR=

# Optional: requests stuck in 'picked_up' longer than this become 'error'.
TIMEOUT_MINUTES=10

# Auto-invoke a fresh `claude --print` per request to process it.
# Set AUTO_INVOKE=false to fall back to a manually-driven bridge-agent session.
AUTO_INVOKE=true
CLAUDE_BIN=claude

