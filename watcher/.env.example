# Copy to .env on the VM and fill in.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Bridge directory layout (folders auto-created at startup).
# Default: ~/cellar27-bridge on Linux/macOS.
# On Windows, set to e.g. C:/Users/<your-username>/cellar27-bridge
BRIDGE_DIR=

# Requests stuck in 'picked_up' longer than this are swept by the DB
# function cellar27_sweep_stale_claims: reset to 'pending' (up to 2
# retries), then 'error'.
TIMEOUT_MINUTES=10

# Global circuit breaker: max number of `claude --print` spawns per
# UTC day across all users. Tracked in cellar27_watcher_metrics in
# Postgres so it survives watcher restarts. Tune to taste.
MAX_CLAUDE_CALLS_PER_DAY=250

# Watcher-side per-user rate limit (in-memory, cleared on restart).
# Redundant with the DB-layer cellar27_check_rate_limit; this is the
# defense-in-depth backstop. Bump if you ever bulk-add inventory.
WATCHER_RATE_LIMIT_PER_HOUR=100

# ── Email notifications when a limit fires ─────────────────────────
# Leave any of these blank to disable notifications silently.
# Gmail: use an App Password (Account Settings → Security → 2FA →
# App passwords). Resend / Mailgun / SES SMTP also work.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_FROM=
NOTIFY_TO=
# Suppress further sends of the same limit-key for this many ms
# after one fires. Default 30 min.
NOTIFY_COOLDOWN_MS=1800000

# Auto-invoke a fresh `claude --print` per request to process it.
# Set AUTO_INVOKE=false to fall back to a manually-driven bridge-agent session.
AUTO_INVOKE=true
CLAUDE_BIN=claude

# Comma-separated user UUIDs allowed to consume bridge compute.
# Get a user's UUID from: select id, email from auth.users;
# Empty/unset = open mode — only safe if Supabase "Allow new users to
# sign up" is OFF.
ALLOWED_USER_IDS=

# ── Current weather context (Open-Meteo, no API key) ───────────────
# If LOCATION_LAT and LOCATION_LON are set, the watcher fetches current
# temperature + conditions and adds them to every Claude request, so
# recommendations can react to actual weather instead of the model
# hallucinating "warm spring day" from the timezone alone. Cached 30 min;
# 4s timeout; degrades silently if the API is down or these are unset.
# LOCATION_NAME is optional and just makes the prompt read more naturally
# ("48°F, drizzle, high 52°F in <name>").
# Find your coords with any maps app (right-click → "What's here").
LOCATION_LAT=
LOCATION_LON=
LOCATION_NAME=

